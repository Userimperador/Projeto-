# Comando `/painel` usando Slash Commands

@bot.tree.command(name="painel", description="Envia o painel de configuração de moderação.")

async def painel_slash(interaction: discord.Interaction):

    if str(interaction.user.id) not in ADMINISTRADORES:

        await interaction.response.send_message("❌ Apenas administradores podem usar este comando!", ephemeral=True)

        return



    embed = discord.Embed(

        title="🔧 Painel de Moderação",

        description="Use os botões abaixo para configurar as proteções do servidor.",

        color=discord.Color.blue()

    )

    embed.add_field(name="👤 Administrador:", value=f"<@{interaction.user.id}>", inline=False)

    embed.set_footer(text="Apenas administradores podem usar os comandos.")



    await interaction.response.send_message(embed=embed, view=PainelModeracao())



# Comando "lula painel" usando prefixo

@bot.command(name="painel")

async def painel_prefix(ctx):

    if str(ctx.author.id) not in ADMINISTRADORES:

        await ctx.send("❌ Apenas administradores podem usar este comando!")

        return



    embed = discord.Embed(

        title="🔧 Painel de Moderação",

        description="Use os botões abaixo para configurar as proteções do servidor.",

        color=discord.Color.blue()

    )

    embed.add_field(name="👤 Administrador:", value=f"<@{ctx.author.id}>", inline=False)

    embed.set_footer(text="Apenas administradores podem usar os comandos.")



    await ctx.send(embed=embed, view=PainelModeracao())



# Evento de inicialização e sincronização dos Slash Commands

@bot.event

async def on_ready():

    try:

        await bot.tree.sync()

        print(f"✅ Bot {bot.user} está online e comandos sincronizados!")

    except Exception as e:

        print(f"❌ Erro ao sincronizar comandos: {e}")





bot.run("")
