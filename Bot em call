ADMINISTRADORES = ["793700485085134870", "1335351341379358821" "1149324560479559720"]



# Classe para o Painel Interativo de Moderação

class PainelModeracao(discord.ui.View):

    def __init__(self):

        super().__init__(timeout=None)  # O painel fica ativo indefinidamente



    @discord.ui.button(label="Entrar na Call", style=discord.ButtonStyle.green, emoji="🎤")

    async def entrar_call(self, interaction: discord.Interaction, button: discord.ui.Button):

        if str(interaction.user.id) not in ADMINISTRADORES:

            await interaction.response.send_message("❌ Apenas administradores podem usar este comando!", ephemeral=True)

            return



        if interaction.user.voice:  # Verifica se o usuário está em um canal de voz

            canal = interaction.user.voice.channel

            await canal.connect()

            await interaction.response.send_message(f"✅ Entrei na call **{canal.name}**!", ephemeral=False)

        else:

            await interaction.response.send_message("⚠️ Você precisa estar em um canal de voz!", ephemeral=True)



    @discord.ui.button(label="Sair da Call", style=discord.ButtonStyle.red, emoji="🚪")

    async def sair_call(self, interaction: discord.Interaction, button: discord.ui.Button):

        if str(interaction.user.id) not in ADMINISTRADORES:

            await interaction.response.send_message("❌ Apenas administradores podem usar este comando!", ephemeral=True)

            return



        if interaction.guild.voice_client:

            await interaction.guild.voice_client.disconnect()

            await interaction.response.send_message("👋 Saí do canal de voz!", ephemeral=False)

        else:

            await interaction.response.send_message("⚠️ Não estou em nenhum canal de voz!", ephemeral=True)



    @discord.ui.button(label="Configurar Blacklist", style=discord.ButtonStyle.grey, emoji="🚫")

    async def blacklist_button(self, interaction: discord.Interaction, button: discord.ui.Button):

        if str(interaction.user.id) not in ADMINISTRADORES:

            await interaction.response.send_message("❌ Apenas administradores podem usar este comando!", ephemeral=True)

            return

        await interaction.response.send_message("🔧 **Blacklist configurada com sucesso!**", ephemeral=False)



    @discord.ui.button(label="Configurar Anti-Marcações", style=discord.ButtonStyle.grey, emoji="🔕")

    async def anti_marcacoes_button(self, interaction: discord.Interaction, button: discord.ui.Button):

        if str(interaction.user.id) not in ADMINISTRADORES:

